<div class="contact-page__bottom-form">
  <div class="container">
    <div class="contact-page__bottom-form-inner">
      <div class="title-box">
        <h2>Let's Get in Touch</h2>
        <p>
          Your email address will not be published. Required fields are marked *
        </p>
      </div>
      <div class="contact-page__bottom-form-inner-box">
        <form
          id="contactForm"
          class="contact-page__form contact-form-validated"
        >
          <div class="row">
            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-12">
              <div class="contact-page__input-box">
                <input type="text" placeholder="Nama" name="name" />
              </div>
            </div>
            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-12">
              <div class="contact-page__input-box">
                <input type="text" placeholder="No. Whatsapp" name="phone" />
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-12">
              <div class="contact-page__input-box">
                <input
                  type="text"
                  placeholder="Company / Brand"
                  name="company"
                />
              </div>
            </div>
            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-12">
              <div class="contact-page__input-box">
                <input
                  type="text"
                  placeholder="Omzet per Bulan"
                  name="income"
                />
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12">
              <div class="contact-page__input-box">
                <textarea name="message" placeholder="Apa yang bisa dibantu?"
                ></textarea>
              </div>
              <div class="contact-page__btn">
                <button
                  id="submitBtn"
                  class="thm-btn"
                  type="submit"
                  data-loading-text="Please wait..."
                >
                  <span class="txt"> Kirim Pesan </span>
                </button>
              </div>
            </div>
          </div>
        </form>

        <!-- Status message -->
        <div id="formStatus" style="display:none; margin-top: 16px; font-weight: 500;"></div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzvzB73oceCkb81N0MMuZRlYCROPql_xWKXl4TsTnH6Do4RDo7Dg5BqwNka8DBbGS442A/exec";

  document.getElementById("contactForm").addEventListener("submit", async function (e) {
    e.preventDefault();

    const btn = document.getElementById("submitBtn");
    const status = document.getElementById("formStatus");
    const form = e.target;

    const payload = {
      name: form.name.value.trim(),
      phone: form.phone.value.trim(),
      company: form.company.value.trim(),
      income: form.income.value.trim(),
      message: form.message.value.trim(),
    };

    // Loading state
    btn.disabled = true;
    btn.querySelector(".txt").textContent = "Mengirim...";
    status.style.display = "none";

    try {
      await fetch(SCRIPT_URL, {
        method: "POST",
        mode: "no-cors",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      status.style.display = "block";
      status.style.color = "#28a745";
      status.textContent = "Pesan berhasil dikirim! Kami akan segera menghubungi Anda.";
      form.reset();

    } catch (err) {
      status.style.display = "block";
      status.style.color = "#dc3545";
      status.textContent = "Gagal mengirim pesan. Silakan coba lagi.";

    } finally {
      btn.disabled = false;
      btn.querySelector(".txt").textContent = "Kirim Pesan";
    }
  });
</script>
