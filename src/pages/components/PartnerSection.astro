---
const clientCategories = [
  {
    name: "Website",
    clients: [
      "/assets/img/brand/brand-v3-1.png",
      "/assets/img/brand/brand-v3-2.png",
      "/assets/img/brand/brand-v3-3.png",
      "/assets/img/brand/brand-v3-4.png",
      "/assets/img/brand/brand-v3-5.png",
      "/assets/img/brand/brand-v3-6.png",
    ],
  },
  {
    name: "Ads",
    clients: [
      "/assets/img/brand/brand-v3-7.png",
      "/assets/img/brand/brand-v3-8.png",
      "/assets/img/brand/brand-v3-9.png",
      "/assets/img/brand/brand-v3-10.png",
    ],
  },
  {
    name: "Social Media",
    clients: [
      "/assets/img/brand/brand-v3-11.png",
      "/assets/img/brand/brand-v3-12.png",
      "/assets/img/brand/brand-v3-13.png",
      "/assets/img/brand/brand-v3-14.png",
    ],
  },
];
---

<section class="about-three">
  <div class="container">
    <div class="sec-title-three text-center mb-4">
      <h4>Our Clients</h4>
    </div>

    <!-- MAIN SWIPER -->
    <div class="swiper client-category-slider">
      <div class="swiper-wrapper">

        {clientCategories.map((category) => (
          <div class="swiper-slide">
            <div class="category-slide">


              <!-- GRID CLIENT -->
              <div class="client-grid">
                {category.clients.map((logo) => (
                  <div class="client-card">
                    <img src={logo} alt="client logo" />
                  </div>
                ))}
              </div>
              <p class="text-center mt-4">{category.name}</p>

            </div>
          </div>
        ))}

      </div>

      <!-- navigation -->
      <!-- <div class="swiper-pagination"></div> -->
    </div>
  </div>
</section>

<script>
import Swiper from "swiper";
  new Swiper(".client-category-slider", {
    slidesPerView: 1,
    spaceBetween: 30,
    loop: true,
    autoHeight: true,

    autoplay: {
      delay: 3500,
      disableOnInteraction: false,
    },

    pagination: {
      el: ".swiper-pagination",
      clickable: true,
    },
  });
</script>
